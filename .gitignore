# =========================================================================
# 1. قواعد أمن البيانات والأرشيف المحلي المعتمدة للنظام (حاسمة جداً)
# =========================================================================
storage_secure/
node_modules/
files/
*.xlsx
*.xls
*.csv
*.jpeg
*.jpg
*.pin
*.pdf
# =========================================================================
# 2. بيئات العمل الافتراضية والمكتبات (Python Virtual Environments)
# =========================================================================
# لمنع رفع آلاف الملفات الخاصة بالمكتبات المستوردة مثل pandas و openpyxl
.venv/
venv/
ENV/
env/
dist/
build/
*.egg-info/

# =========================================================================
# 3. الملفات المؤقتة والملفات المخفية لنظام التشغيل (OS Generated)
# =========================================================================
# لمنع رفع ملفات مصغرات الصور والنظام الخاصة بـ Windows أو Mac
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# =========================================================================
# 4. ملفات الكاش الخاصة بـ Python (Pycache)
# =========================================================================
# ملفات تسريع التشغيل الفورية التي تولدها لغة بايثون تلقائياً
**/__pycache__/
*.py[cod]
*$py.class

# =========================================================================
# 5. ملفات التكوين والبيئات الحساسة (Environment Variables)
# =========================================================================
# في حال قمنا لاحقاً بإنشاء ملف .env لتخزين مسار المجلد الخارجي ديناميكياً
.env
.env.local
